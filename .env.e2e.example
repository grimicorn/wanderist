# Mapbox — https://account.mapbox.com/access-tokens/ → create a public token
# Optional for e2e: the Map page degrades gracefully without it.
NUXT_PUBLIC_MAPBOX_TOKEN=

# Neon branch for e2e tests
E2E_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk webhook signing secret — https://dashboard.clerk.com → Webhooks → your endpoint → Signing Secret
NUXT_CLERK_WEBHOOK_SECRET=whsec_...

# Netlify Blobs — required for media upload e2e tests.
# See .env.example for instructions on obtaining these values.
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=

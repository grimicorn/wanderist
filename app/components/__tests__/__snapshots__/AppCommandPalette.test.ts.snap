// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AppCommandPalette > renders the panel when open and matches snapshot 1`] = `
"<div class="cmdk is-open" role="dialog" aria-label="Search">
  <div class="cmdk__scrim"></div>
  <div class="cmdk__panel">
    <div class="cmdk__search"><svg data-icon="" name="search" size="18"></svg><input class="cmdk__input" placeholder="Search places, trips, entries, people…" autocomplete="off" spellcheck="false"><span class="kbd">esc</span></div>
    <div class="cmdk__results">
      <div class="cmdk__group">
        <div class="cmdk__glabel">Quick actions</div><a class="cmdk__item is-active"><span class="cmdk__ico"><svg data-icon="" name="plus" size="15"></svg></span><span class="cmdk__txt"><span class="cmdk__t">New entry</span><span class="cmdk__s">Write a journal entry</span></span><svg data-icon="" name="arrow-right" size="15" class="cmdk__go"></svg></a><a class="cmdk__item"><span class="cmdk__ico"><svg data-icon="" name="pin" size="15"></svg></span><span class="cmdk__txt"><span class="cmdk__t">Drop a pin</span><span class="cmdk__s">Add a place to your map</span></span><svg data-icon="" name="arrow-right" size="15" class="cmdk__go"></svg></a><a class="cmdk__item"><span class="cmdk__ico"><svg data-icon="" name="route" size="15"></svg></span><span class="cmdk__txt"><span class="cmdk__t">New trip</span><span class="cmdk__s">Start planning a route</span></span><svg data-icon="" name="arrow-right" size="15" class="cmdk__go"></svg></a><a class="cmdk__item"><span class="cmdk__ico"><svg data-icon="" name="map" size="15"></svg></span><span class="cmdk__txt"><span class="cmdk__t">Open map</span><span class="cmdk__s">See your world</span></span><svg data-icon="" name="arrow-right" size="15" class="cmdk__go"></svg></a><a class="cmdk__item"><span class="cmdk__ico"><svg data-icon="" name="settings" size="15"></svg></span><span class="cmdk__txt"><span class="cmdk__t">Settings</span><span class="cmdk__s">Account &amp; preferences</span></span><svg data-icon="" name="arrow-right" size="15" class="cmdk__go"></svg></a>
      </div>
    </div>
    <div class="cmdk__foot"><span class="cmdk__keys"><span class="kbd">↑</span><span class="kbd">↓</span> to navigate</span><span class="cmdk__keys"><span class="kbd">↵</span> to open</span><span class="cmdk__brand">wanderist</span></div>
  </div>
</div>"
`;

          <div data-v-a25903e0="" class="stop__card">
            <div data-v-a25903e0="" class="stop__top">
              <div data-v-a25903e0="">
                <div data-v-a25903e0="" class="stop__name">Höfn</div>
                <div data-v-a25903e0="" class="stop__sub">
                  <!--v-if-->
                  <!--v-if-->
                </div>
              </div><span data-v-a25903e0="" class="stop__grip"><svg data-v-a25903e0="" data-icon="" name="grip" size="16"></svg></span>
            </div>
            <!--v-if-->
            <div data-v-a25903e0="" class="stop__foot"><span data-v-a25903e0="" class="m"><svg data-v-a25903e0="" data-icon="" name="ruler" size="12"></svg> 180 km</span></div>
          </div>
        </div>

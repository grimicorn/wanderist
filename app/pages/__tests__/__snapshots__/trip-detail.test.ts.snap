        </div>
        <div data-v-a25903e0="" style="padding: 13px 16px;"><a data-v-a25903e0="" href="/map" class="btn btn--outline btn--sm btn--block"><svg data-v-a25903e0="" data-icon="" name="map" size="14"></svg> open in full map </a></div>

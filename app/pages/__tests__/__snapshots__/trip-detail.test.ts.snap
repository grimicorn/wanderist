// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Trip Detail page (/trips/[id]) > renders without crashing and matches snapshot 1`] = `
"<div data-v-a25903e0="" class="content content--wide" style="padding-top: 0px;">
  <!-- Hero -->
  <div data-v-a25903e0="" class="thero ph" style="">
    <div data-v-a25903e0="" class="topo"></div>
    <div data-v-a25903e0="" class="thero__veil"></div>
    <div data-v-a25903e0="" class="thero__acts"><button data-v-a25903e0="" class="btn btn--outline btn--sm" style="background: rgba(255, 255, 255, 0.12); border-color: rgba(255, 255, 255, 0.4); color: #fff;"><svg data-v-a25903e0="" data-icon="" name="image" size="14"></svg> edit cover</button><input data-v-a25903e0="" type="file" accept="image/*" style="display: none;"><button data-v-a25903e0="" class="btn btn--outline btn--sm" style="background: rgba(255, 255, 255, 0.12); border-color: rgba(255, 255, 255, 0.4); color: #fff;"><svg data-v-a25903e0="" data-icon="" name="globe" size="14"></svg> share</button></div>
    <div data-v-a25903e0="" class="thero__in">
      <div data-v-a25903e0="" class="label">// ongoing trip</div>
      <h1 data-v-a25903e0="">Iceland, the ring road</h1>
      <div data-v-a25903e0="" class="thero__meta"><span data-v-a25903e0=""><svg data-v-a25903e0="" data-icon="" name="calendar" size="14"></svg> Jun 9 – Jun 17</span><span data-v-a25903e0=""><svg data-v-a25903e0="" data-icon="" name="pin" size="14"></svg> 3 stops  · 1,332 km</span><span data-v-a25903e0=""><svg data-v-a25903e0="" data-icon="" name="image" size="14"></svg> 61 photos</span></div>
    </div>
  </div>
  <!--v-if-->
  <!--v-if-->
  <div data-v-a25903e0="" class="tdcols">
    <!-- Itinerary -->
    <div data-v-a25903e0="">
      <div data-v-a25903e0="" class="iti-head">
        <div data-v-a25903e0="">
          <div data-v-a25903e0="" class="label">// itinerary</div>
          <h2 data-v-a25903e0="" class="display" style="font-size: 20px; margin-top: 8px;"> Route &amp; stops </h2>
        </div><button data-v-a25903e0="" class="btn btn--ghost btn--sm"><svg data-v-a25903e0="" data-icon="" name="sliders" size="14"></svg> reorder </button>
      </div>
      <div data-v-a25903e0="" class="iti">
        <div data-v-a25903e0="" class="stop is-done">
          <div data-v-a25903e0="" class="stop__node">
            <div data-v-a25903e0="" class="stop__pin"><svg data-v-a25903e0="" data-icon="" name="check" size="18"></svg></div>
          </div>
          <div data-v-a25903e0="" class="stop__card">
            <div data-v-a25903e0="" class="stop__top">
              <div data-v-a25903e0="">
                <div data-v-a25903e0="" class="stop__name">Reykjavík</div>
                <div data-v-a25903e0="" class="stop__sub"><svg data-v-a25903e0="" data-icon="" name="calendar" size="12"></svg> Jun 9 · 2 nights
                  <!--v-if-->
                </div>
              </div><span data-v-a25903e0="" class="stop__grip"><svg data-v-a25903e0="" data-icon="" name="grip" size="16"></svg></span>
            </div>
            <p data-v-a25903e0="" class="stop__note">Landed, picked up the camper.</p>
            <div data-v-a25903e0="" class="stop__foot">
              <!--v-if-->
            </div>
          </div>
        </div>
        <div data-v-a25903e0="" class="stop is-next">
          <div data-v-a25903e0="" class="stop__node">
            <div data-v-a25903e0="" class="stop__pin"><svg data-v-a25903e0="" data-icon="" name="pin" size="18"></svg></div>
          </div>
          <div data-v-a25903e0="" class="stop__card">
            <div data-v-a25903e0="" class="stop__top">
              <div data-v-a25903e0="">
                <div data-v-a25903e0="" class="stop__name">Jökulsárlón</div>
                <div data-v-a25903e0="" class="stop__sub">
                  <!--v-if--><span data-v-a25903e0="" class="tag tag--accent">next</span>
                </div>
              </div><span data-v-a25903e0="" class="stop__grip"><svg data-v-a25903e0="" data-icon="" name="grip" size="16"></svg></span>
            </div>
            <!--v-if-->
            <div data-v-a25903e0="" class="stop__foot"><span data-v-a25903e0="" class="m"><svg data-v-a25903e0="" data-icon="" name="ruler" size="12"></svg> 270 km</span></div>
          </div>
        </div>
        <div data-v-a25903e0="" class="stop">

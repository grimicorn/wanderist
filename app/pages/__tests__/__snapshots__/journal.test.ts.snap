// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Journal page (/journal) > renders without crashing and matches snapshot 1`] = `
"<div data-v-59046aa4="" class="content">
  <header data-v-59046aa4="" class="topbar">
    <div data-v-59046aa4="" class="feed-tabs"><button data-v-59046aa4="" class="is-active">Timeline</button><button data-v-59046aa4="" class="">By trip</button><button data-v-59046aa4="" class="">Photos</button></div><button data-v-59046aa4="" class="btn btn--primary btn--sm"><svg data-v-59046aa4="" data-icon="" name="plus" size="14"></svg> new entry </button>
  </header>
  <div data-v-59046aa4="" class="jcols">
    <!-- Feed -->
    <div data-v-59046aa4="" class="feed">
      <!-- Compose bar — clicking anywhere opens the new-entry drawer -->
      <div data-v-59046aa4="" class="compose" role="button" tabindex="0" aria-label="Write a new entry"><span data-v-59046aa4="" class="compose__av"><svg data-v-59046aa4="" data-icon="" name="user" size="18"></svg></span><input data-v-59046aa4="" readonly="" placeholder="Write an entry, or drop today's photos…">
        <div data-v-59046aa4="" class="acts"><button data-v-59046aa4="" class="icon-btn" aria-label="Add photo"><svg data-v-59046aa4="" data-icon="" name="image" size="18"></svg></button><button data-v-59046aa4="" class="icon-btn" aria-label="Add location"><svg data-v-59046aa4="" data-icon="" name="pin" size="18"></svg></button></div>
      </div><!-- Loading state -->
      <!-- Timeline tab: entries grouped by day -->
      <div data-v-59046aa4="" class="day-div"><span data-v-59046aa4="" class="label">// Jun 12</span></div>
      <article data-v-59046aa4="" class="post">
        <h3 class="post__title">Harbor at 4am</h3><button class="like"><span class="cnt">24</span></button>
      </article>
      <div data-v-59046aa4="" class="day-div"><span data-v-59046aa4="" class="label">// Jun 8</span></div>
      <article data-v-59046aa4="" class="post">
        <h3 class="post__title">Tram 28, again</h3><button class="like"><span class="cnt">41</span></button>
      </article>
      <!--v-if-->
    </div><!-- Right rail -->
    <aside data-v-59046aa4="" class="rail">
      <!-- Active trip card -->
      <div data-v-59046aa4="" class="rail-card">
        <h4 data-v-59046aa4="" class="display"> Active trip <a data-v-59046aa4="" href="/trips/trip-1" class="label label--plain" style="font-size: 10px;">stats</a></h4>
        <div data-v-59046aa4="" class="trip-hero ph" style="height: 90px; border-radius: 8px; position: relative; overflow: hidden;">
          <div data-v-59046aa4="" class="topo" style="opacity: 0.5;"></div>
        </div>
        <div data-v-59046aa4="" style="font-family: var(--font-display); font-weight: 600; font-size: 15px; margin-top: 10px;">Iceland, the ring road</div>
        <div data-v-59046aa4="" class="progress" style="height: 6px; border-radius: 99px; background: var(--line); overflow: hidden; margin: 10px 0px 6px;"><span data-v-59046aa4="" style="display: block; height: 100%; width: 100%; background: var(--accent); border-radius: 99px;"></span></div>
        <div data-v-59046aa4="" class="hstack" style="justify-content: space-between; font-size: 11px; color: var(--muted);"><span data-v-59046aa4="">day 9 of 9</span><span data-v-59046aa4="">1 entry</span></div>
      </div><!-- Trips list -->
      <div data-v-59046aa4="" class="rail-card">
        <h4 data-v-59046aa4="" class="display">Trips</h4>
        <div data-v-59046aa4="" class="trip-pill"><span data-v-59046aa4="" class="trip-pill__sw" style="background: var(--bg-tint);"><span data-v-59046aa4="" class="topo" style="opacity: 0.6;"></span></span>
          <div data-v-59046aa4="">
            <div data-v-59046aa4="" class="trip-pill__name">Iceland, the ring road</div>
            <div data-v-59046aa4="" class="trip-pill__sub">1 entry · ongoing</div>

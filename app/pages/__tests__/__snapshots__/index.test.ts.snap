  <section data-v-16d9afef="" id="how" class="lp-sec">
    <div data-v-16d9afef="" class="lp">
      <div data-v-16d9afef="" class="sec-head" data-reveal="">
        <div data-v-16d9afef="" class="label">// 03 — how it works</div>
        <h2 data-v-16d9afef="">Three taps from <b data-v-16d9afef="">here to remembered.</b></h2>
      </div>
      <div data-v-16d9afef="" class="steps" data-reveal-stagger="" data-reveal-step="120">
        <div data-v-16d9afef="" class="step">

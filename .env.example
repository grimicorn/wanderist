# Mapbox — https://account.mapbox.com/access-tokens/ → create a public token
# Required for the Map page. Leave blank to show the placeholder instead of a live map.
NUXT_PUBLIC_MAPBOX_TOKEN=

# Neon DB — https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Clerk — https://dashboard.clerk.com → API Keys
NUXT_CLERK_SECRET_KEY=sk_test_...
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Clerk webhook signing secret — https://dashboard.clerk.com → Webhooks → your endpoint → Signing Secret
NUXT_CLERK_WEBHOOK_SECRET=whsec_...

# Sentry — https://sentry.io → Settings → Projects → Client Keys (DSN)
NUXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=danholloran
SENTRY_PROJECT=wanderist

# Instagram Graph API — https://developers.facebook.com → My Apps → your app → Settings
# Requires a Facebook App connected to a Business or Creator Instagram account.
# Set the OAuth redirect URI in the app dashboard to: https://<your-domain>/api/connections/instagram/callback
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Token encryption — used to encrypt OAuth access tokens stored in the database.
# Generate a secure key with: openssl rand -hex 32
# Must be a 64-character hex string (32 bytes / 256 bits).
TOKEN_ENCRYPTION_KEY=

# Public origin — used to build the Instagram OAuth redirect URI server-side.
# Example: https://wanderist.app  (no trailing slash)
NUXT_PUBLIC_SITE_ORIGIN=http://localhost:3000

# Netlify Blobs — used for media file storage (uploads).
# These are auto-injected by Netlify at runtime (Functions / SSR). You do NOT
# need to set them when deploying; Netlify provides them automatically.
# For local development outside of `netlify dev`, set them manually:
#   NETLIFY_SITE_ID  — your Netlify project ID (Project settings → General)
#   NETLIFY_AUTH_TOKEN — a personal access token (User settings → OAuth → Personal access tokens)
# Leave these blank when running via `netlify dev`; the CLI injects them.
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
